PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=phylogenydb
DB_TYPE=postgres
DB_SYNCHRONIZE=true
SALT_ROUNDS=10
JWT_SECRET=change_this_to_a_strong_secret
JWT_EXPIRES_IN=1h
# MinIO (S3-compatible) configuration
# Endpoint and port for the MinIO server
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
# Set to 'true' if using HTTPS
MINIO_USE_SSL=false
# Credentials for the MinIO root user (match docker-compose)
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
# Default Bucket for matrices and visualizations
MINIO_MATRIX_BUCKET=matrices
MINIO_VISUALIZATION_BUCKET=visualizations

#Frontend origin for CORS
FRONT_ORIGIN=http://localhost:3000